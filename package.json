{
  "name": "godmode",
  "version": "0.9.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build -w @godmode/kernel -w @godmode/flow-core -w @godmode/plugin-api -w @godmode/plugin-host",
    "dev": "concurrently \"npm run dev -w @godmode/bridge\" \"npm run dev -w @godmode/web\"",
    "dev:bridge": "npm run dev -w @godmode/bridge",
    "dev:web": "npm run dev -w @godmode/web",
    "typecheck": "npm run build:packages && npm run typecheck --workspaces --if-present",
    "audit:oss": "node scripts/audit-oss-core.mjs",
    "audit:kernel": "node scripts/audit-kernel-coverage.mjs && node scripts/audit-kernel-direct-writes.mjs && node scripts/audit-kernel-writable.mjs && node scripts/audit-kernel-ownership-parity.mjs && node scripts/audit-kernel-read-write-symmetry.mjs",
    "audit:kernel:strict": "node scripts/audit-kernel-strict.mjs",
    "audit:kernel:parity": "node scripts/audit-kernel-parity.mjs --strict",
    "test": "vitest run",
    "test:audit": "node --test scripts/__tests__/audit-kernel.test.mjs scripts/__tests__/audit-kernel-parity.test.mjs",
    "test:release": "node --test scripts/release/__tests__/*.test.mjs",
    "release:verify": "node scripts/release/verify-release.mjs",
    "test:objecttypes": "vitest run packages/kernel/src packages/plugin-api/src apps/bridge/src/kernel apps/web/src",
    "test:gate": "npm run build:packages && npm run typecheck && npm run audit:kernel:strict && npm run audit:oss && npm run test:audit && npm run test:release && npm test",
    "seed:demo": "node scripts/seed-readme-demo.mjs",
    "plugins": "tsx scripts/godmode-plugins-cli.ts",
    "package:desktop": "node scripts/release/package-desktop.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
