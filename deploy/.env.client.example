# GodMode client (personal Docker) — copy to deploy/.env.client
# Never commit the real file.

GODMODE_IMAGE=ghcr.io/OWNER/godmode@sha256:REPLACE_WITH_RELEASE_DIGEST
DEPLOYMENT_MODE=client
INSTALLATION_SURFACE=docker
UPDATE_CHANNEL=stable
UPDATE_READINESS_TOKEN=replace-with-separate-random-supervisor-token
# Optional one-click apply through a dedicated host supervisor:
# UPDATE_SUPERVISOR_URL=http://host.docker.internal:8799/
# UPDATE_SUPERVISOR_TOKEN=replace-with-separate-random-supervisor-token

WEB_PUBLIC_URL=http://localhost:8080
AUTH_PUBLIC_URL=http://localhost:8080
WEB_ORIGIN=http://localhost:8080

# Official hub for marketplace catalog authority
CLOUD_HUB_URL=https://hub.example.com

AUTH_SESSION_SECRET=replace-with-32-plus-random-bytes
AUTH_ALLOW_ANONYMOUS=false
AUTH_ALLOW_SIGNUP=true

BRIDGE_PORT=3847
BRIDGE_HOST=127.0.0.1
PLATFORM_DATA_DIR=/data
