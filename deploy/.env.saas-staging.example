# SaaS staging beside an existing private hub (e.g. Z440 family hub).
# Copy to deploy/.env.saas-staging — never commit the real file.

GODMODE_IMAGE=ghcr.io/reboticsai/godmode@sha256:REPLACE_WITH_RELEASE_DIGEST

# Host port must not collide with the private hub (often 8080).
SAAS_HOST_PORT=9080
# Optional bind mount (Z440 example). Omit to use the compose named volume.
# SAAS_DATA_DIR=/mnt/storage/godmode-saas-data

DEPLOYMENT_MODE=hub
INSTALLATION_SURFACE=saas

# Public URLs as browsers reach this staging instance
WEB_PUBLIC_URL=http://127.0.0.1:9080
AUTH_PUBLIC_URL=http://127.0.0.1:9080
WEB_ORIGIN=http://127.0.0.1:9080

AUTH_SESSION_SECRET=replace-with-32-plus-random-bytes
AUTH_ALLOW_ANONYMOUS=false
AUTH_ALLOW_SIGNUP=false
AUTH_INVITE_CODES=

# Seed your operator admin (not paywalled)
INITIAL_ADMINS=Admin:you@example.com
# INITIAL_ADMIN_PASSWORD=only-for-bootstrap-then-change

# Stripe — create a Product/Price in test mode, then:
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_ publishable key can also be set in Admin → Billing after login
STRIPE_SAAS_PRICE_ID=price_...
STRIPE_SAAS_CHECKOUT_MODE=payment
STRIPE_WEBHOOK_SECRET=whsec_...
# Forward webhooks while testing:
#   stripe listen --forward-to http://127.0.0.1:9080/api/saas/stripe/webhook

BRIDGE_PORT=3847
BRIDGE_HOST=127.0.0.1
PLATFORM_DATA_DIR=/data
UPDATE_CHANNEL=stable
