# GodMode hub (production SaaS) — copy to deploy/.env.production
# Never commit the real file.

GODMODE_IMAGE=ghcr.io/OWNER/godmode@sha256:REPLACE_WITH_RELEASE_DIGEST
DEPLOYMENT_MODE=hub
INSTALLATION_SURFACE=saas
UPDATE_CHANNEL=stable
UPDATE_READINESS_TOKEN=replace-with-separate-random-supervisor-token
# Optional one-click apply through a dedicated host supervisor:
# UPDATE_SUPERVISOR_URL=http://host.docker.internal:8799/
# UPDATE_SUPERVISOR_TOKEN=replace-with-separate-random-supervisor-token

# Public URLs (no trailing slash)
WEB_PUBLIC_URL=https://app.example.com
AUTH_PUBLIC_URL=https://api.example.com
WEB_ORIGIN=https://app.example.com

# Required
AUTH_SESSION_SECRET=replace-with-32-plus-random-bytes
AUTH_ALLOW_ANONYMOUS=false
AUTH_ALLOW_SIGNUP=false
AUTH_INVITE_CODES=

# Pre-seed platform admins: Name:email,Name:email
INITIAL_ADMINS=Admin:admin@example.com

# Optional Stripe (marketplace credits — configure via Admin → Billing after boot)
# STRIPE_SECRET_KEY=
# STRIPE_CREDITS_PER_USD=100

# Federation (optional — for cross-bridge sharing)
FEDERATION_TOKEN=
FEDERATION_PUBLIC_URL=https://api.example.com

BRIDGE_PORT=3847
BRIDGE_HOST=127.0.0.1
PLATFORM_DATA_DIR=/data
