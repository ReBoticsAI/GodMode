# GodMode hub (production SaaS) — copy to deploy/.env.production
# Never commit the real file.

GODMODE_IMAGE=ghcr.io/OWNER/godmode@sha256:REPLACE_WITH_RELEASE_DIGEST
DEPLOYMENT_MODE=hub
INSTALLATION_SURFACE=saas
UPDATE_CHANNEL=stable
UPDATE_READINESS_TOKEN=replace-with-separate-random-supervisor-token
# Optional one-click apply through a dedicated host supervisor:
# UPDATE_SUPERVISOR_URL=http://host.docker.internal:8799/
# UPDATE_SUPERVISOR_TOKEN=replace-with-separate-random-supervisor-token

# Public URLs (no trailing slash)
WEB_PUBLIC_URL=https://app.example.com
AUTH_PUBLIC_URL=https://api.example.com
WEB_ORIGIN=https://app.example.com

# Required
AUTH_SESSION_SECRET=replace-with-32-plus-random-bytes
AUTH_ALLOW_ANONYMOUS=false
AUTH_ALLOW_SIGNUP=false
AUTH_INVITE_CODES=

# Pre-seed platform admins: Name:email,Name:email
INITIAL_ADMINS=Admin:admin@example.com

# SaaS paywall (INSTALLATION_SURFACE=saas only — ignored on private_hub)
# Create Product "GodMode Cloud" with USD monthly ($9.99) + yearly ($74.99) Prices, then:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_SAAS_CHECKOUT_MODE=subscription
# STRIPE_SAAS_PRICE_MONTHLY=price_...
# STRIPE_SAAS_PRICE_YEARLY=price_...
# Sandbox (ReBotics test): monthly price_1TuEaJPAFoYyWIoUk9MI17ae / yearly price_1TuEaQPAFoYyWIoUNPvHfTXs
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://app.example.com/api/saas/stripe/webhook
# Event: checkout.session.completed

# Optional Stripe marketplace credits — also configurable via Admin → Billing
# STRIPE_CREDITS_PER_USD=100

# Federation (optional — for cross-bridge sharing)
FEDERATION_TOKEN=
FEDERATION_PUBLIC_URL=https://api.example.com

BRIDGE_PORT=3847
BRIDGE_HOST=127.0.0.1
PLATFORM_DATA_DIR=/data

# Public marketing site (Cloudflare Pages from sites/www) — required before live Stripe
BUSINESS_WEBSITE_URL=https://www.example.com

# Transactional email (do not use Hostinger shared mailbox)
EMAIL_PROVIDER=resend
EMAIL_FROM=GodMode <noreply@example.com>
RESEND_API_KEY=re_...
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Optional OAuth
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# Offsite backups (optional — local snapshots under PLATFORM_DATA_DIR are first-party)
# BACKUP_LOCAL_DIR=/data/backups
# BACKUP_S3_ENDPOINT=https://s3.example.com
# BACKUP_S3_REGION=auto
# BACKUP_S3_BUCKET=godmode-backups
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_PREFIX=godmode/

# Keep false unless you explicitly accept agent RCE / local plugin risk on SaaS
PLATFORM_SAAS_ALLOW_CODE_ACCESS=false
PLATFORM_SAAS_ALLOW_LOCAL_PLUGINS=false
