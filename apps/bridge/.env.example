# Optional third-party integrations (copy to .env and fill in)
# AES-256-GCM hex key; auto-generated to data dir if omitted
HOLDINGS_SECRET_KEY=
MORALIS_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
HOLDINGS_CRYPTO_CHAINS=eth,polygon,bsc,arbitrum,optimism,base,avalanche

# Auth (email/password + sessions)
AUTH_PUBLIC_URL=http://127.0.0.1:3847
WEB_PUBLIC_URL=http://127.0.0.1:5173
WEB_ORIGIN=http://127.0.0.1:5173
# local | hub | client
DEPLOYMENT_MODE=local
# Client mode: official hub for marketplace (no trailing slash)
CLOUD_HUB_URL=
AUTH_SESSION_SECRET=change-me-in-production
AUTH_ALLOW_ANONYMOUS=false
# Set AUTH_ALLOW_ANONYMOUS=true only for headless local tooling — never on a network-exposed host.
AUTH_ALLOW_SIGNUP=true
AUTH_INVITE_CODES=
# Optional password for INITIAL_ADMINS seed users (local/client only)
INITIAL_ADMIN_PASSWORD=
# Pre-seeded platform admins (Name:email, comma-separated; emails must match signup/login).
# Leave empty for OSS: the first signup becomes platform admin automatically.
INITIAL_ADMINS=
AUTH_SESSION_TTL_DAYS=30
FEDERATION_TOKEN=
FEDERATION_PUBLIC_URL=http://127.0.0.1:3847

# Stripe marketplace credits (hub SaaS mode only; not used in local OSS)
# STRIPE_SECRET_KEY=
# STRIPE_CREDITS_PER_USD=100

# Platform paths (optional overrides)
PLATFORM_DATA_DIR=
PLATFORM_REPO_ROOT=

# Bridge
BRIDGE_PORT=3847
BRIDGE_HOST=127.0.0.1

# Optional domain plugins (semicolon-separated on Windows). See docs/PLUGIN_AUTHORING.md.
# GODMODE_PLUGIN_PATH=

# Private GitHub plugin repos (Marketplace installType: plugin with pluginRepo HTTPS URL)
# GITHUB_TOKEN=

# Dev-only: allow any browser Origin when not in production (default: WEB_ORIGIN only)
# CORS_PERMISSIVE=true

# Optional: Cursor subscription / contractor (User API key from cursor.com/dashboard)
# CURSOR_API_KEY=

# Embeddings (semantic memory + wiki RAG). Hub: attach to host EmbeddingGemma on :8082.
# EMBEDDINGS_ENABLED=true
# EMBEDDINGS_EXTERNAL=true
# EMBEDDINGS_SERVER_HOST=host.docker.internal
# EMBEDDINGS_PORT=8082
# EMBEDDINGS_MODEL_PATH=
