{
  "name": "@godmode/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "GodMode desktop shell (Electron)",
  "author": {
    "name": "ReBotics AI",
    "email": "250840102+ReBoticsAI@users.noreply.github.com"
  },
  "homepage": "https://github.com/ReBoticsAI/GodMode",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "37.10.3",
    "electron-builder": "26.15.3",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "ai.rebotics.godmode",
    "productName": "GodMode",
    "executableName": "GodMode",
    "copyright": "Copyright © ReBotics AI",
    "electronVersion": "37.10.3",
    "directories": {
      "output": "../../release-out/desktop",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/runtime",
        "to": "runtime"
      },
      {
        "from": "resources/update",
        "to": "update"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "godmode-windows-desktop-v${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "GodMode"
    },
    "afterPack": "./after-pack.cjs",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "godmode-macos-${arch}-desktop-v${version}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "artifactName": "godmode-linux-desktop-v${version}.${ext}"
    },
    "publish": null
  }
}
