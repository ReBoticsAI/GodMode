{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godmode.dev/schemas/release-manifest-v1.json",
  "title": "GodMode release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "channel", "commit", "publishedAt", "releaseNotes", "compatibility", "policy", "signing", "image", "artifacts"],
  "properties": {
    "schema": { "const": "https://godmode.dev/schemas/release-manifest-v1.json" },
    "version": { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+(?:-(?:nightly\\.\\d{8}\\.[0-9a-f]{7,40}|[0-9A-Za-z.-]+))?$" },
    "channel": { "enum": ["nightly", "stable"] },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "releaseNotes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "summary"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://" },
        "summary": { "type": "string", "maxLength": 20000 }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "kernelClientApi", "schema", "connectors"],
      "properties": {
        "engine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum"],
          "properties": {
            "minimum": { "type": "string" },
            "maximum": { "type": "string" }
          }
        },
        "kernelClientApi": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum"],
          "properties": {
            "minimum": { "type": "integer", "minimum": 1 },
            "maximum": { "type": "integer", "minimum": 1 }
          }
        },
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum", "rollbackMinimum"],
          "properties": {
            "minimum": { "type": "integer", "minimum": 0 },
            "maximum": { "type": "integer", "minimum": 0 },
            "rollbackMinimum": { "type": "integer", "minimum": 0 }
          }
        },
        "connectors": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mandatory", "security"],
      "properties": {
        "mandatory": { "type": "boolean" },
        "security": { "type": "boolean" }
      }
    },
    "signing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "issuer", "identity", "bundle"],
      "properties": {
        "method": { "const": "sigstore-keyless" },
        "issuer": { "const": "https://token.actions.githubusercontent.com" },
        "identity": { "type": "string", "pattern": "^https://github\\.com/ReBoticsAI/GodMode/\\.github/workflows/release\\.yml@refs/(heads/main|tags/v\\d+\\.\\d+\\.\\d+)$" },
        "bundle": { "const": "release-manifest.json.bundle" }
      }
    },
    "pluginConstraints": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "coordinatedPlugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "sha256"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "commit", "platforms"],
      "properties": {
        "repository": { "type": "string", "pattern": "^ghcr\\.io/" },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "platforms": {
          "type": "array",
          "items": { "enum": ["linux/amd64", "linux/arm64"] },
          "minItems": 2,
          "uniqueItems": true
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "platform", "version", "commit", "sha256", "size"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "kind": { "enum": ["bundle", "installer", "sbom", "provenance"] },
          "platform": {
            "enum": [
              "linux-x64",
              "windows-x64",
              "darwin-x64",
              "darwin-arm64",
              "multi"
            ]
          },
          "version": { "type": "string" },
          "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
